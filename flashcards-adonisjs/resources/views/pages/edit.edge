<!DOCTYPE html>
<html>
  <head>
    <title>
      Modifier - {{ deck.title }}
    </title>
    @vite(['resources/css/app.css'])

  </head>
  <body>
    @include('partials/header')
    <main>
      <h1>
        Modifier le deck : {{ deck.title }}
      </h1>

      <h3>
        Cartes actuelles
      </h3>
      <table>
        <thead>
          <tr>
            <th>
              Question
            </th>
            <th>
              Réponse
            </th>
            <th>
              Actions
            </th>
          </tr>
        </thead>
        <tbody>
          @each(card in deck.flashcards)
            <tr>
              <td>
                {{ card.question }}
              </td>
              <td>
                {{ card.answer }}
              </td>
              <td>
                <a href="{{ route('card.edit', { id: card.id }) }}">
                  Modifier
                </a>
                <form action="{{ route('card.destroy', { id: card.id }) }}?_method=DELETE" method="POST" style="margin: 0;">
                  {{ csrfField() }}
                  <button type="submit" onclick="return confirm('êtes-vous sûr de supprimer cette flashcard ?')" style="background: none; border: none; cursor: pointer; color: red; font-size: 1rem; padding: 0;">
                    Supprimer
                  </button>
                </form>
              </td>
            </tr>
          @end
        </tbody>
      </table>

      <hr />

      <h3>
        Ajouter une nouvelle carte
      </h3>
      <form action="{{ route('deck.addCard', { id: deck.id }) }}" method="POST">
        {{ csrfField() }}
        <div>
          <label>Question (Recto) :</label>
          <input type="text" name="question" required />
        </div>
        <div>
          <label>Réponse (Verso) :</label>
          <input type="text" name="answer" required />
        </div>
        <button type="submit" class="btn-ajouter">Enregistrer la carte</button>
      </form>
      <h3>
        Modifer le deck
      </h3>
      <form action="{{ route('deck.update', { id: deck.id }) }}" method="POST">
        {{ csrfField() }}
        <div>
          <label for="title">Titre du deck :</label>
          <input type="text" id="title" name="title" value="{{ deck.title }}" required />
        </div>

        <div>
          <label for="description">Description :</label>
          <textarea id="description" name="description" >{{ deck.description || '' }}</textarea>
        </div>
         <select name="categoryId" id="categoryId">
          <option value="">
            Modifier la catégorie
          </option>
          @each(category in categories)
            <option value="{{ category.id }}" {{ deck.categoryId === category.id ? 'selected' : '' }}>
              {{ category.name }}
            </option>
          @end
        </select>
        <button type="submit" class="btn-ajouter">Enregistrer les modifications</button>
      </form>

      <br />
      <a href="{{ route('deck') }}">Retour aux decks</a>
    </main>
  </body>
</html>
