<!DOCTYPE html>
<html>
  <head>
    <title>
      Accueil
    </title>
    @vite(['resources/css/app.css'])
  </head>
  <body>
    @include('partials/header')
    <main>
      @if(flashMessages.has('success'))
        <div style="background-color: #5cff47; color: #111010; padding: 10px; margin-bottom: 20px; border: 1px solid #000; text-align: center;">
            {{ flashMessages.get('success') }}
        </div>
      @end
      <h1>
        Mes decks
      </h1>

      <table>
        <thead>
          <tr>
            <th>
              Titre (Étudier)
            </th>
            <th>
              Description
            </th>
            <th>
              Categorie
            </th>
            <th>
              Nombre de Cartes
            </th>
            <th>
              Actions
            </th>
          </tr>
        </thead>
        <tbody>
          @each(deck in decks)

            <tr>
              <td>
                <a href="{{ route('deck.study', { id: deck.id }) }}" class="link-study">
                  <strong>{{ deck.title }}</strong>
                </a>
              </td>
              <td>
                {{ deck.description }}
              </td>
              <td>
                {{ deck.category.name }}
              </td>
              <td>
                {{ deck.$extras.flashcards_count }}
              </td>
              <td style="display: flex; align-items: center; gap: 10px;">
                <a href="{{ route('deck.edit', { id: deck.id }) }}">Ajouter / Modifier</a>

                <form action="{{ route('deck.destroy', { id: deck.id }) }}" method="POST" style="margin: 0;">
                  {{ csrfField() }}
                  <button type="submit" style="background: none; border: none; cursor: pointer; color: red; font-size: 1rem; padding: 0;">
                    Supprimer
                  </button>
                </form>
              </td>
            </tr>
          @end
        </tbody>
      </table>

      <button type="button" class="btn-ajouter" onclick="window.location.href='{{ route('deck.create') }}'">
        Ajouter un nouveau deck
      </button>
    </main>
  </body>
</html>
