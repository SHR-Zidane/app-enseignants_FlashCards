<!DOCTYPE html>
<html>
  <head>
    <title>
      Étude - {{ deck.title }}
    </title>
    @vite(['resources/css/app.css'])
  </head>
  <body>
    @include('partials/header')
    <main class="study-container">
      <h1>
        {{ deck.title }}
      </h1>

      <div id="flashcard-box" class="flashcard">
        @if(deck.flashcards.length > 0)
          @each((card, index) in deck.flashcards)
            <div class="card-item" id="card-{{ index }}" style="{{ index === 0 ? '' : 'display:none' }}">
              <div class="card-front" id="front-{{index}}" onclick="showAnswer({{ index }})">
                <h3>
                  Question
                </h3>
                <p class="content">
                  {{ card.question }}
                </p>
              </div>

              <div id="answer-{{index}}" class="card-back" style="display:none; text-align:center;">
                <h3>
                  Réponse
                </h3>
                <p class="content">
                  {{ card.answer }}
                </p>
                <div class="actions">
                  <button onclick="registerResult('juste'); nextCard({{ index }});">Juste</button>
                  <button onclick="registerResult('faux'); nextCard({{ index }});">Faux</button>
                </div>
              </div>
              <a href="{{ route('deck') }}">Retour à l'accueil</a>
            </div>
          @end
          <div id="final-result" style="display:none; text-align:center; padding: 20px;">
            <h2>Quiz terminé !</h2>
            <p>Votre score final est : <span id="final-score-value"></span> / {{ deck.flashcards.length }}</p>
            <a href="{{ route('deck') }}" class="btn-next">retour à l'accueil</a>
          </div>
        @else
          <p>
            Ce deck ne contient aucune carte.
          </p>
          <a href="{{ route('deck') }}">Retour à l'accueil</a>
        @end
      </div>
    </main>

    <script>
      let score = 0;

      function registerResult(isCorrect) {
        if (isCorrect === 'juste') {
          score++;
        }
      }
      function showAnswer(index) {
        const answerBlock = document.getElementById(`answer-${index}`);

        const questionBlock = document.getElementById(`front-${index}`);

        answerBlock.style.display = "block";

        questionBlock.style.display = "none";
      }

      function nextCard(index) {
        const currentCard = document.getElementById(`card-${index}`);
        const nextCard = document.getElementById(`card-${index + 1}`);
        if (nextCard) {
          currentCard.style.display = "none";
          nextCard.style.display = "block";
        } else {

          currentCard.style.display = "none";

          document.getElementById('final-result').style.display = "block";

          document.getElementById('final-score-value').innerText = score;

          document.querySelector('h1').style.display = "none";        }
      }
    </script>
  </body>
</html>
